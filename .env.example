# --- LLM provider ---
# "groq" = free, fast inference (default). Get a free key at https://console.groq.com/keys
# "openai" = paid, requires OPENAI_API_KEY below
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

# Only needed if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# --- Embedding provider ---
# "local" = free, runs on your machine via sentence-transformers (default, no key needed)
# "openai" = requires OPENAI_API_KEY, small cost
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Vector store ---
CHROMA_DIR=./data/chroma_db
COLLECTION_NAME=tech_docs

# --- Corpus ---
CORPUS_DIR=./corpus

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Retrieval / self-correction ---
TOP_K=4
MAX_RETRIES=2

# --- Feedback log ---
FEEDBACK_LOG=./data/feedback/feedback.jsonl

# --- Bonus features ---
ENABLE_HALLUCINATION_CHECK=true
ENABLE_WEB_SEARCH_FALLBACK=false
TAVILY_API_KEY=
